generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  githubUserId      BigInt    @unique
  login             String
  name              String?
  avatarUrl         String?
  githubAccessToken String
  tokenType         String?
  scope             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions Session[]
  scans    Scan[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Repo {
  id              String   @id @default(cuid())
  githubRepoId    BigInt?  @unique
  owner           String
  name            String
  fullName        String
  description     String?
  defaultBranch   String   @default("main")
  stars           Int      @default(0)
  openIssuesCount Int      @default(0)
  isPrivate       Boolean  @default(false)
  language        String?
  url             String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scans Scan[]

  @@unique([owner, name])
}

model Scan {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  repo        Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId      String
  status      String    @default("pending") // pending | ready | deepening | complete | error
  stage       String    @default("created") // created | initial | deepened
  summary     String?
  issueCount  Int       @default(0)
  prCount     Int       @default(0)
  costUsd     Float?
  latencyMs   Int?
  packetJson  Json      @default("{}")
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  traceSteps ScanTraceStep[]

  @@index([userId, createdAt])
  @@index([repoId, createdAt])
  @@index([status, createdAt])
}

model ScanTraceStep {
  id         String    @id @default(cuid())
  scan       Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  scanId     String
  stepType   String
  stepName   String
  status     String    @default("done") // pending | running | done | error
  inputJson  Json      @default("{}")
  outputJson Json?
  latencyMs  Int?
  costUsd    Float?
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([scanId, startedAt])
}
